stashDierr(who,ERR)	; Compose the FileMan DIERR text into ^TMP($job,"vslfs","err").
"RTN","VSLFS",100,0)
	new m,nl,seq
"RTN","VSLFS",101,0)
	set nl=$char(10)
"RTN","VSLFS",102,0)
