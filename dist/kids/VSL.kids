"RTN","VSLTAP",76,0)
	; doc: @example   kill ^VSLTAP do arm^VSLTAP(),off^VSLTAP() do eq^STDASSERT(.pass,.fail,$$captureOn^VSLTAP(),0,"OFF -> capture gate cannot run") kill ^VSLTAP
"RTN","VSLTAP",77,0)
	set ^VSLTAP("cfg","mode")="off"
"RTN","VSLTAP",78,0)
