"RTN","VSLS3",164,0)
drain(res)	; Flush the ^XTMP ring to S3 as one LDJSON batch, then trim the shipped entries.
"RTN","VSLS3",165,0)
	; doc: @param res  array  OUT by-ref: res("shipped")/("key")/("body")/("status")
"RTN","VSLS3",166,0)
	; doc: @returns    int    the number of records shipped (0 if gated/empty/failed)
"RTN","VSLS3",167,0)
	; doc: The whole egress path runs in the SEPARATE flush process (VSLTASK calls
"RTN","VSLS3",168,0)
	; doc: this) — never the RPC CPU (§4.1.3). It is consumer-gated AND auto-
"RTN","VSLS3",169,0)
	; doc: failover-aware: it ships ONLY while the Phase-2 gate is enabled, so a
"RTN","VSLS3",170,0)
	; doc: dead/slow sink or any interference signal turns it off cleanly (the gate
"RTN","VSLS3",171,0)
	; doc: records the off-window). On a 200 it self-drains the shipped seqs
"RTN","VSLS3",172,0)
	; doc: (drainTo^VSLTAP); on any other status it leaves the ring for retry.
"RTN","VSLS3",173,0)
	new ctx,opt,bucket,station,proto,h,t,seq,rec,body,line,n,last,key,sc
"RTN","VSLS3",174,0)
	kill res
"RTN","VSLS3",175,0)
	set res("shipped")=0
"RTN","VSLS3",176,0)
	; consumer-gate + auto-failover (the Phase-2 safety reflexes) — fail-safe-OFF.
"RTN","VSLS3",177,0)
	if '$$enabled^VSLTAP() quit 0
"RTN","VSLS3",178,0)
	set h=$$head^VSLTAP(),t=$$tail^VSLTAP()
"RTN","VSLS3",179,0)
	if h'>t quit 0
"RTN","VSLS3",180,0)
	set bucket=$$ctx(.ctx,.opt)
"RTN","VSLS3",181,0)
	set station=$$cfg^VSLTAP("s3station","")
"RTN","VSLS3",182,0)
	set proto=$$cfg^VSLTAP("s3proto","rpc")
"RTN","VSLS3",183,0)
	; assemble the batch: one LDJSON line per retained record, in seq order. The
"RTN","VSLS3",184,0)
	; ring (tail,head] is contiguous (append +1's head; only drainTo/trim KILL,
"RTN","VSLS3",185,0)
	; from the tail up), so every seq in range is present — ship them ALL,
"RTN","VSLS3",186,0)
	; including a genuinely-empty captured record, so nothing is silently dropped.
"RTN","VSLS3",187,0)
	set body="",n=0,last=0
"RTN","VSLS3",188,0)
	for seq=t+1:1:h do
"RTN","VSLS3",189,0)
	. set rec=$$read^VSLTAP(seq)
"RTN","VSLS3",190,0)
	. set line=$$envelope(rec,proto,$$cfg^VSLTAP("s3dir",""),station,seq,.opt)
"RTN","VSLS3",191,0)
	. set body=body_line_$char(10),n=n+1,last=seq
"RTN","VSLS3",192,0)
	if 'n quit 0
"RTN","VSLS3",193,0)
	set key=$$key(station,proto,last)
"RTN","VSLS3",194,0)
	set sc=$$shipBatch(.ctx,bucket,key,body,.opt,.res)
"RTN","VSLS3",195,0)
	set res("key")=key,res("body")=body,res("status")=sc
"RTN","VSLS3",196,0)
	; ship failed -> leave the ring intact for the next flush tick (no trim).
"RTN","VSLS3",197,0)
	if sc'=200 quit 0
"RTN","VSLS3",198,0)
	do drainTo^VSLTAP(h)
"RTN","VSLS3",199,0)
	set res("shipped")=n
"RTN","VSLS3",200,0)
	quit n
"RTN","VSLS3",201,0)
	;
"RTN","VSLS3",202,0)
shipBatch(ctx,bucket,key,body,opt,resp)	; (private) ship one batch object; honour the capture-sink test seam.
"RTN","VSLS3",203,0)
	; doc: The §6.2-style injected seam: with ^VSLTAP("cfg","s3sink")="capture"
"RTN","VSLS3",204,0)
	; doc: the batch is returned in `res` (no real PUT) so the drain logic is
"RTN","VSLS3",205,0)
	; doc: provable on a bare engine; otherwise it PUTs via the STDS3 monopoly.
"RTN","VSLS3",206,0)
	if $$cfg^VSLTAP("s3sink","")="capture" quit 200
"RTN","VSLS3",207,0)
	quit $$ship(.ctx,bucket,key,$get(body),.opt,.resp)
"RTN","VSLSEC")
0^105^0^0
"RTN","VSLSEC",1,0)
VSLSEC	; v-stdlib — VistA identity/authorization adapter (Kernel).
"RTN","VSLSEC",2,0)
	;
"RTN","VSLSEC",3,0)
	; Binds the VistA *authorization decision* — the part of the security seam
"RTN","VSLSEC",4,0)
	; that has NO portable analog and so cannot live below the waterline. Three
"RTN","VSLSEC",5,0)
	; bindings, each VistA-only:
"RTN","VSLSEC",6,0)
	;   - the security-key check ($$hasKey, over Kernel's ^XUSEC);
"RTN","VSLSEC",7,0)
	;   - the ambient principal ($$duz, the NEW PERSON #200 IEN);
"RTN","VSLSEC",8,0)
	;   - the principal -> #200 NAME resolution ($$user), which REUSES VSLFS
"RTN","VSLSEC",9,0)
	;     (v->v composition; no FileMan DBS re-bind — waterline §9 no-duplication
"RTN","VSLSEC",10,0)
	;     applies within `v` too).
"RTN","VSLSEC",11,0)
	;
"RTN","VSLSEC",12,0)
	; *** NO portable crypto here — STDCRYPTO owns it. *** Portable token crypto
"RTN","VSLSEC",13,0)
	; (SHA digests, HMAC, constant-time compare) lives in STDCRYPTO (libcrypto on
"RTN","VSLSEC",14,0)
	; YDB / $SYSTEM.Encryption on IRIS, dual-engine proven) and is called up by a
"RTN","VSLSEC",15,0)
	; consumer that needs it. VSLSEC binds NO Kernel hash back end: grounded
"RTN","VSLSEC",16,0)
	; 2026-06-16, there is no portable Kernel generic-hash entry point —
"RTN","VSLSEC",17,0)
	; $$SHAHASH^XUSHSH is absent on the YDB-VistA test engine (pre XU*8.0*655)
"RTN","VSLSEC",18,0)
	; and the classic top-level ^XUSHSH returns a constant on both engines. The
"RTN","VSLSEC",19,0)
	; architecture (§3.4) is explicit: "Portable token crypto stays in STD*; the
"RTN","VSLSEC",20,0)
	; VistA authorization decision lives in VSL." This module is that decision.
"RTN","VSLSEC",21,0)
	;
"RTN","VSLSEC",22,0)
	; Public API:
"RTN","VSLSEC",23,0)
	;   $$hasKey^VSLSEC(key,duz) — 1 iff `duz` holds security key `key`, else 0
"RTN","VSLSEC",24,0)
	;   $$duz^VSLSEC()           — the ambient principal (+$GET(DUZ), the #200 IEN)
"RTN","VSLSEC",25,0)
	;   $$user^VSLSEC(duz)       — the #200 NAME for `duz` (via VSLFS), else ""
"RTN","VSLSEC",26,0)
	;   $$lastError^VSLSEC()     — last error detail, else ""
"RTN","VSLSEC",27,0)
	;
"RTN","VSLSEC",28,0)
	; *** ERROR CONTRACT — loud on a malformed call, never on a normal DENY ***
"RTN","VSLSEC",29,0)
	; An authorization DENY is a normal `0` from $$hasKey — NOT an error. A
"RTN","VSLSEC",30,0)
	; malformed call (an empty key name) maps to a clean ,U-VSL-SEC-ARG, $ECODE,
"RTN","VSLSEC",31,0)
	; with the detail in ^TMP($job,"vslsec","err") for $$lastError. This mirrors
"RTN","VSLSEC",32,0)
	; VSLFS's loud-failure posture (a real fault is loud; an absent value is not).
"RTN","VSLSEC",33,0)
	;
"RTN","VSLSEC",34,0)
	; ICR note: ^XUSEC is the documented Supported *reference* for security-key
"RTN","VSLSEC",35,0)
	; membership ("do not reference the SECURITY KEY (#19.1) file ... check the
"RTN","VSLSEC",36,0)
	; ^XUSEC global ... this is (and continues to be) a supported reference" —
"RTN","VSLSEC",37,0)
	; Kernel DG, Security Keys). It carries no numeric DBIA in the gold corpus, so
"RTN","VSLSEC",38,0)
	; the call is tagged with the notional ICR marker (a read, never a write — the
"RTN","VSLSEC",39,0)
	; no-direct-global rule forbids set/kill, not the Supported $D reference). See
"RTN","VSLSEC",40,0)
	; docs/memory notional-dbia-not-a-blocker + plan §5.4.
"RTN","VSLSEC",41,0)
	;
"RTN","VSLSEC",42,0)
	quit
"RTN","VSLSEC",43,0)
	;
"RTN","VSLSEC",44,0)
	; ---------- the authorization decision (the VistA binding) ----------
"RTN","VSLSEC",45,0)
	;
"RTN","VSLSEC",46,0)
hasKey(key,duz)	; 1 iff `duz` (default: the ambient DUZ) holds security key `key`.
"RTN","VSLSEC",47,0)
	; doc: @param   key      string   security-key name (SECURITY KEY #19.1 .01)
"RTN","VSLSEC",48,0)
	; doc: @param   duz      numeric  the user's #200 IEN; defaults to +$GET(DUZ)
"RTN","VSLSEC",49,0)
	; doc: @returns          bool     1 iff the user holds the key; 0 (a normal DENY) otherwise
"RTN","VSLSEC",50,0)
	; doc: @raises  U-VSL-SEC-ARG  the call is malformed (an empty key name)
"RTN","VSLSEC",51,0)
	; doc: @icr notional @call ^XUSEC @status Supported @custodian XU @source XU/krn_8_0_dg_security_keys_ug#key-lookup
"RTN","VSLSEC",52,0)
	if $get(key)="" do raiseArg("hasKey","a key name is required") quit ""
"RTN","VSLSEC",53,0)
	quit ''$data(^XUSEC(key,$$pduz(duz)))
"RTN","VSLSEC",54,0)
	;
"RTN","VSLSEC",55,0)
duz()	; The ambient principal — +$GET(DUZ), the caller's NEW PERSON (#200) IEN.
"RTN","VSLSEC",56,0)
	; doc: @returns          numeric  the ambient DUZ (0 when no signon context is set)
"RTN","VSLSEC",57,0)
	quit +$get(DUZ)
"RTN","VSLSEC",58,0)
	;
"RTN","VSLSEC",59,0)
user(duz)	; The #200 NAME for `duz` (default: the ambient DUZ), resolved via VSLFS.
"RTN","VSLSEC",60,0)
	; doc: @param   duz      numeric  the user's #200 IEN; defaults to +$GET(DUZ)
"RTN","VSLSEC",61,0)
	; doc: @returns          string   the NEW PERSON (#200) .01 NAME, or "" if absent
"RTN","VSLSEC",62,0)
	; doc: Reuses $$get^VSLFS (FileMan DBS) — the principal->#200 binding without
"RTN","VSLSEC",63,0)
	; doc: re-binding the DBS (v->v composition; waterline §9 no-duplication).
"RTN","VSLSEC",64,0)
	quit $$get^VSLFS(200,$$pduz(duz)_",",".01","")
"RTN","VSLSEC",65,0)
	;
"RTN","VSLSEC",66,0)
bySecid(secid)	; The #200 IEN for a SecID via EN1^XUPSQRY (RPC XUPS PERSONQUERY), else "".
"RTN","VSLSEC",67,0)
	; doc: @param   secid    string   the IAM Security ID (SECID, NEW PERSON #200 field #205.1)
"RTN","VSLSEC",68,0)
	; doc: @returns          numeric  the #200 IEN bound to that SecID, or "" if none / not on a VistA engine
"RTN","VSLSEC",69,0)
	; doc: @raises  U-VSL-SEC-ARG  the call is malformed (an empty SecID)
"RTN","VSLSEC",70,0)
	; doc: @icr 4575 @call EN1^XUPSQRY @status Controlled Subscription @custodian XU @source XU/krn_8_0_dg_common_services_ug#en1xupsqry-query-new-person-file
"RTN","VSLSEC",71,0)
	; doc: The SSOi/2FA identity binding: a federated subject (the SecID claim of a
"RTN","VSLSEC",72,0)
	; doc: validated token) -> the local #200 IEN, the way Kernel's own XUSAML/
"RTN","VSLSEC",73,0)
	; doc: XUESSO2 resolve an STS SAML token. EN1^XUPSQRY queries #200 by SecID
"RTN","VSLSEC",74,0)
	; doc: (param 2; null last name in param 3) and stuffs a by-ref result array
"RTN","VSLSEC",75,0)
	; doc: (result(1)=1/0 found-flag; result(1,0)=VPID^IEN^name~...). On a bare
"RTN","VSLSEC",76,0)
	; doc: engine (EN1^XUPSQRY absent) this returns "" — the caller $text-gates the
"RTN","VSLSEC",77,0)
	; doc: live path. No direct ^VA(200 read: the lookup is the Controlled-
"RTN","VSLSEC",78,0)
	; doc: Subscription API and the IEN is read from the returned array (waterline).
"RTN","VSLSEC",79,0)
	new RESULT
"RTN","VSLSEC",80,0)
	if $get(secid)="" do raiseArg("bySecid","a SecID is required") quit ""
"RTN","VSLSEC",81,0)
	if $text(EN1^XUPSQRY)="" quit ""
"RTN","VSLSEC",82,0)
	do EN1^XUPSQRY(.RESULT,secid,"")
"RTN","VSLSEC",83,0)
	quit $$parseQry(.RESULT)
"RTN","VSLSEC",84,0)
	;
"RTN","VSLSEC",85,0)
parseQry(result)	; Extract the #200 IEN from an EN1^XUPSQRY result array, or "".
"RTN","VSLSEC",86,0)
	; doc: @internal
"RTN","VSLSEC",87,0)
	; doc: result(1) is the found-flag (1 found / 0 not found); result(1,0) is the
"RTN","VSLSEC",88,0)
	; doc: first record, VPID^IEN^LastName~First~Middle^SSN^DOB^SEX^ — the IEN is
"RTN","VSLSEC",89,0)
	; doc: ^-piece 2. Pure (no VistA) so it is unit-tested on a bare engine.
"RTN","VSLSEC",90,0)
	if +$get(result(1))'=1 quit ""
"RTN","VSLSEC",91,0)
	quit $piece($get(result(1,0)),"^",2)
"RTN","VSLSEC",92,0)
	;
"RTN","VSLSEC",93,0)
lastError()	; The last VSLSEC error message (the composed malformed-call detail).
"RTN","VSLSEC",94,0)
	; doc: @returns          string   ^TMP($job,"vslsec","err"), or "" if none
"RTN","VSLSEC",95,0)
	quit $get(^TMP($job,"vslsec","err"))
"RTN","VSLSEC",96,0)
	;
"RTN","VSLSEC",97,0)
	; ---------- internals ----------
"RTN","VSLSEC",98,0)
	;
"RTN","VSLSEC",99,0)
pduz(duz)	; Resolve the effective principal: `duz` if supplied, else the ambient DUZ.
"RTN","VSLSEC",100,0)
	quit $select($get(duz)'="":duz,1:+$get(DUZ))
"RTN","VSLSEC",101,0)
	;
"RTN","VSLSEC",102,0)
raiseArg(who,msg)	; Stash the detail, then raise the clean ,U-VSL-SEC-ARG,.
"RTN","VSLSEC",103,0)
	set ^TMP($job,"vslsec","err")=who_": "_msg
"RTN","VSLSEC",104,0)
	set $ecode=",U-VSL-SEC-ARG,"
"RTN","VSLSEC",105,0)
	quit
"RTN","VSLTAP")
0^236^0^0
"RTN","VSLTAP",1,0)
VSLTAP	; v-stdlib — non-interference traffic-tap core (the safety gate).
"RTN","VSLTAP",2,0)
	;
"RTN","VSLTAP",3,0)
	; Phase 2 / M1 of the RPC+HL7 -> S3 traffic tap (spec §6/§4.1). VSLTAP is the
"RTN","VSLTAP",4,0)
	; load-bearing capture core everything downstream waits behind. Its whole job
"RTN","VSLTAP",5,0)
	; is to be INVISIBLE to the clinical RPC flow it observes: a bounded, rolling
"RTN","VSLTAP",6,0)
	; ^XTMP ring filled by an irreducible memory-copy append, gated three ways
"RTN","VSLTAP",7,0)
	; (operator kill-switch / consumer-presence / always-on opt-in), fenced so any
"RTN","VSLTAP",8,0)
	; fault self-disables instead of touching the caller, and watched so ANY
"RTN","VSLTAP",9,0)
	; interference signal flips the tap OFF automatically (fail-safe-OFF).
"RTN","VSLTAP",10,0)
	;
"RTN","VSLTAP",11,0)
	; *** Layer: v (above the m/v waterline). It touches ^XTMP (Kernel's SAC-
"RTN","VSLTAP",12,0)
	; sanctioned scratch global) and consumes `m` utilities DOWN (STDDATE for the
"RTN","VSLTAP",13,0)
	; FileMan purge-date); it never inverts the dependency. The egress/VistA
"RTN","VSLTAP",14,0)
	; bindings (XPAR config source, VSLRPC chokepoint, Kernel XQ82 purge schedule)
"RTN","VSLTAP",15,0)
	; are SEAMS, not Phase-2 dependencies — so the gate runs on a BARE engine with
"RTN","VSLTAP",16,0)
	; no VistA and no S3 (kickoff). Config/state ride in ^VSLTAP (small control
"RTN","VSLTAP",17,0)
	; state); the rolling capture cache rides in ^XTMP("VSLTAP",…) (the auto-
"RTN","VSLTAP",18,0)
	; purged scratch global, §4.1.1 — no FileMan file).
"RTN","VSLTAP",19,0)
	;
"RTN","VSLTAP",20,0)
	; Capture buffer (the rolling "flight recorder", §4.1, Option A / D-10):
"RTN","VSLTAP",21,0)
	;   ^XTMP("VSLTAP",0)            purgedate^createdate^description (Kernel XQ82)
"RTN","VSLTAP",22,0)
	;   ^XTMP("VSLTAP","head")       highest written seq
"RTN","VSLTAP",23,0)
	;   ^XTMP("VSLTAP","tail")       (lowest-retained seq) - 1
"RTN","VSLTAP",24,0)
	;   ^XTMP("VSLTAP","data",seq)   the verbatim record (no transform)
"RTN","VSLTAP",25,0)
	;
"RTN","VSLTAP",26,0)
	; Control state (^VSLTAP — VSL namespace):
"RTN","VSLTAP",27,0)
	;   ^VSLTAP("cfg",key)           mode/consumer/alwayson/cap/maxbytes/latbound/…
"RTN","VSLTAP",28,0)
	;   ^VSLTAP("disabled")          auto-failover reason, else absent
"RTN","VSLTAP",29,0)
	;   ^VSLTAP("hb")                liveness heartbeat ($H)
"RTN","VSLTAP",30,0)
	;   ^VSLTAP("_offwindows")       count; (,n)=open^reason^close (explicit, never silent)
"RTN","VSLTAP",31,0)
	;   ^VSLTAP("hl",…)              health counters/samples (VSLTAPHL)
"RTN","VSLTAP",32,0)
	;   ^VSLTAP("fc","last")         last fidelity manifest line (VSLTAPFC persist)
"RTN","VSLTAP",33,0)
	;
"RTN","VSLTAP",34,0)
	; Public API:
"RTN","VSLTAP",35,0)
	;   $$enabled^VSLTAP()           1 iff capture should run now (the one gate)
"RTN","VSLTAP",36,0)
	;   $$append^VSLTAP(rec)         gated memory-copy append -> 1 captured / 0 not
"RTN","VSLTAP",37,0)
	;   $$tee^VSLTAP(rec)            fault-fenced $$append (used by VSLRPCTAP)
"RTN","VSLTAP",38,0)
	;   $$size^VSLTAP() / $$head() / $$tail() / $$read(seq)   ring inspection
"RTN","VSLTAP",39,0)
	;   $$state^VSLTAP()             OFF | ARMED-IDLE | ACTIVE | AUTO-DISABLED | UNHEALTHY
"RTN","VSLTAP",40,0)
	;   $$disabled^VSLTAP()          auto-failover reason or ""
"RTN","VSLTAP",41,0)
	;   do arm() / off() / setConsumer(b) / setAlwaysOn(b)   operator/gate controls
"RTN","VSLTAP",42,0)
	;   do disable(reason) / rearm()  auto-failover OFF / re-arm (records _offwindows)
"RTN","VSLTAP",43,0)
	;   do heartbeat() / $$healthy()  liveness
"RTN","VSLTAP",44,0)
	;   do purgeNode()               write the Kernel auto-purge node
"RTN","VSLTAP",45,0)
	;   $$cfg(key,default)           read a config knob (consumed by VSLTAPHL)
"RTN","VSLTAP",46,0)
	;   $$offWindows(.out)           recorded off-windows -> count
"RTN","VSLTAP",47,0)
	;
"RTN","VSLTAP",48,0)
	quit
"RTN","VSLTAP",49,0)
	;
"RTN","VSLTAP",50,0)
	; ---------- config ----------
"RTN","VSLTAP",51,0)
	;
"RTN","VSLTAP",52,0)
cfg(key,default)	; Read a config knob from ^VSLTAP("cfg",key), else `default`.
"RTN","VSLTAP",53,0)
	; doc: @param key      string  config key (mode/consumer/alwayson/cap/maxbytes/latbound/hbstale/retain)
"RTN","VSLTAP",54,0)
	; doc: @param default  string  value when unset
"RTN","VSLTAP",55,0)
	; doc: @returns        string  the configured value or the default
"RTN","VSLTAP",56,0)
	quit $get(^VSLTAP("cfg",key),default)
"RTN","VSLTAP",57,0)
	;
"RTN","VSLTAP",58,0)
arm()	; Operator: arm the tap (kill-switch ON) and clear any prior auto-disable.
"RTN","VSLTAP",59,0)
	set ^VSLTAP("cfg","mode")="armed"
"RTN","VSLTAP",60,0)
	kill ^VSLTAP("disabled")
"RTN","VSLTAP",61,0)
	quit
"RTN","VSLTAP",62,0)
	;
"RTN","VSLTAP",63,0)
off()	; Operator: kill-switch OFF (state OFF; capture cannot run).
"RTN","VSLTAP",64,0)
	set ^VSLTAP("cfg","mode")="off"
"RTN","VSLTAP",65,0)
	quit
"RTN","VSLTAP",66,0)
	;
"RTN","VSLTAP",67,0)
setConsumer(present)	; Set the consumer-presence flag (D-5): no consumer -> egress/capture OFF.
"RTN","VSLTAP",68,0)
	set ^VSLTAP("cfg","consumer")=+$get(present)
"RTN","VSLTAP",69,0)
	quit
"RTN","VSLTAP",70,0)
	;
"RTN","VSLTAP",71,0)
setAlwaysOn(flag)	; Opt-in always-on flight-recorder (D-8): capture even with no consumer.
"RTN","VSLTAP",72,0)
	set ^VSLTAP("cfg","alwayson")=+$get(flag)
"RTN","VSLTAP",73,0)
	quit
"RTN","VSLTAP",74,0)
	;
"RTN","VSLTAP",75,0)
	; ---------- the capture gate + the rolling ring ----------
"RTN","VSLTAP",76,0)
	;
"RTN","VSLTAP",77,0)
enabled()	; 1 iff capture should run now: armed AND not auto-disabled AND (consumer OR always-on).
"RTN","VSLTAP",78,0)
	; doc: @returns bool  the single capture gate (fail-safe-OFF; consumer-gated default, D-8)
"RTN","VSLTAP",79,0)
	if $$cfg("mode","off")'="armed" quit 0
"RTN","VSLTAP",80,0)
	if $$disabled()'="" quit 0
"RTN","VSLTAP",81,0)
	if +$$cfg("consumer",0) quit 1
"RTN","VSLTAP",82,0)
	if +$$cfg("alwayson",0) quit 1
"RTN","VSLTAP",83,0)
	quit 0
"RTN","VSLTAP",84,0)
	;
"RTN","VSLTAP",85,0)
append(rec)	; Gated, fault-fenced, bounded memory-copy append of a verbatim record.
"RTN","VSLTAP",86,0)
	; doc: @param rec   string  the verbatim payload (no parse, no transform — D-1)
"RTN","VSLTAP",87,0)
	; doc: @returns bool 1 iff captured; 0 iff gated, auto-disabled, copy-cost-tripped, or fenced
"RTN","VSLTAP",88,0)
	; doc: The ONLY in-path op (besides the $G gate): one global SET + bounded trim.
"RTN","VSLTAP",89,0)
	; doc: No LOCK, no serialize, no socket, no I/O, no block (§6.1). Self-fenced:
"RTN","VSLTAP",90,0)
	; doc: ANY fault inside the write self-disables and returns 0 — never the caller.
"RTN","VSLTAP",91,0)
	; doc: Flag-based $ETRAP (ISO, dual-engine; NEVER zgoto, the M4 resident-harness
"RTN","VSLTAP",92,0)
	; doc: gotcha). The write runs in a DO-invoked frame (write1) so the trap's
"RTN","VSLTAP",93,0)
	; doc: argument-less QUIT is legal — an arg-less QUIT trap fired in an extrinsic
"RTN","VSLTAP",94,0)
	; doc: ($$) frame raises M17 NOTEXTRINSIC (per STDASSERT raises()).
"RTN","VSLTAP",95,0)
	new ok,$etrap,wrote
"RTN","VSLTAP",96,0)
	if '$$enabled() quit 0
"RTN","VSLTAP",97,0)
	set ok=1,wrote=0
"RTN","VSLTAP",98,0)
	set $etrap="set ok=0,$ecode="""" quit"
"RTN","VSLTAP",99,0)
	do write1(rec,.wrote)
"RTN","VSLTAP",100,0)
	if ok quit wrote
"RTN","VSLTAP",101,0)
	set $etrap=""
"RTN","VSLTAP",102,0)
	do disable("fault")
"RTN","VSLTAP",103,0)
	quit 0
"RTN","VSLTAP",104,0)
	;
"RTN","VSLTAP",105,0)
write1(rec,wrote)	; (private) the ring write, DO-invoked so the append fence's QUIT is legal.
"RTN","VSLTAP",106,0)
	; doc: @param rec    string  the verbatim payload
"RTN","VSLTAP",107,0)
	; doc: @param wrote  bool    by-ref; set 1 iff the record was appended
"RTN","VSLTAP",108,0)
	new seq,cap
"RTN","VSLTAP",109,0)
	; fault-injection seam — the §6.2 "injected deviation" exit-gate (b) lever.
"RTN","VSLTAP",110,0)
	if +$$cfg("faultinject",0) set $ecode=",U-VSLTAP-INJECT,"
"RTN","VSLTAP",111,0)
	; copy-cost guard (§6.2): a pathological mega-payload trips auto-failover OFF.
"RTN","VSLTAP",112,0)
	if $length(rec)>+$$cfg("maxbytes",1000000) do disable("copycost") quit
"RTN","VSLTAP",113,0)
	set cap=+$$cfg("cap",1000)
"RTN","VSLTAP",114,0)
	set seq=+$get(^XTMP("VSLTAP","head"))+1
"RTN","VSLTAP",115,0)
	set ^XTMP("VSLTAP","data",seq)=rec
"RTN","VSLTAP",116,0)
	set ^XTMP("VSLTAP","head")=seq
"RTN","VSLTAP",117,0)
	do trim(seq,cap)
"RTN","VSLTAP",118,0)
	do record^VSLTAPHL(0,$length(rec),0)
"RTN","VSLTAP",119,0)
	set wrote=1
"RTN","VSLTAP",120,0)
	quit
"RTN","VSLTAP",121,0)
	;
"RTN","VSLTAP",122,0)
trim(seq,cap)	; (private) overwrite-oldest: drop entries until the ring holds at most `cap`.
"RTN","VSLTAP",123,0)
	new t
"RTN","VSLTAP",124,0)
	set t=+$get(^XTMP("VSLTAP","tail"))
"RTN","VSLTAP",125,0)
	for  quit:(seq-t)'>cap  do dropOldest(.t)
"RTN","VSLTAP",126,0)
	set ^XTMP("VSLTAP","tail")=t
"RTN","VSLTAP",127,0)
	quit
"RTN","VSLTAP",128,0)
	;
"RTN","VSLTAP",129,0)
dropOldest(t)	; (private) drop the oldest retained entry and advance the tail cursor.
"RTN","VSLTAP",130,0)
	set t=t+1
"RTN","VSLTAP",131,0)
	kill ^XTMP("VSLTAP","data",t)
"RTN","VSLTAP",132,0)
	quit
"RTN","VSLTAP",133,0)
	;
"RTN","VSLTAP",134,0)
tee(rec)	; The named capture seam the VSLRPC chokepoint calls (VSLRPCTAP) — fenced.
"RTN","VSLTAP",135,0)
	; doc: @param rec   string  the verbatim payload
"RTN","VSLTAP",136,0)
	; doc: @returns bool the $$append result (0 if gated or a fault was fenced)
"RTN","VSLTAP",137,0)
	; doc: $$append is already self-fenced (a DO-framed $ETRAP that self-disables on
"RTN","VSLTAP",138,0)
	; doc: any fault); tee is the stable adapter entry. Either leaves the caller's
"RTN","VSLTAP",139,0)
	; doc: result / $ECODE / $T untouched.
"RTN","VSLTAP",140,0)
	quit $$append(rec)
"RTN","VSLTAP",141,0)
	;
"RTN","VSLTAP",142,0)
size()	; Current ring entry count (head - tail).
"RTN","VSLTAP",143,0)
	quit +$get(^XTMP("VSLTAP","head"))-+$get(^XTMP("VSLTAP","tail"))
"RTN","VSLTAP",144,0)
	;
"RTN","VSLTAP",145,0)
head()	; Highest written seq (0 if empty).
"RTN","VSLTAP",146,0)
	quit +$get(^XTMP("VSLTAP","head"))
"RTN","VSLTAP",147,0)
	;
"RTN","VSLTAP",148,0)
tail()	; (lowest-retained seq) - 1 (0 if empty).
"RTN","VSLTAP",149,0)
	quit +$get(^XTMP("VSLTAP","tail"))
"RTN","VSLTAP",150,0)
	;
"RTN","VSLTAP",151,0)
read(seq)	; The verbatim record at `seq`, or "" if absent/overwritten.
"RTN","VSLTAP",152,0)
	quit $get(^XTMP("VSLTAP","data",+$get(seq)))
"RTN","VSLTAP",153,0)
	;
"RTN","VSLTAP",154,0)
drainTo(seq)	; Post-ship trim: drop retained entries up to and including `seq`, advance tail.
"RTN","VSLTAP",155,0)
	; doc: @param seq  numeric  the highest shipped sequence (bounded to head)
"RTN","VSLTAP",156,0)
	; doc: @returns    void     the drain self-KILLs shipped entries (spec §4.1.3)
"RTN","VSLTAP",157,0)
	; doc: Called by the SEPARATE flush process (VSLS3 $$drain) AFTER a batch ships
"RTN","VSLTAP",158,0)
	; doc: 200 — never from the RPC path. Idempotent; never advances past head.
"RTN","VSLTAP",159,0)
	new t,h
"RTN","VSLTAP",160,0)
	set h=+$get(^XTMP("VSLTAP","head"))
"RTN","VSLTAP",161,0)
	if +$get(seq)>h set seq=h
"RTN","VSLTAP",162,0)
	set t=+$get(^XTMP("VSLTAP","tail"))
"RTN","VSLTAP",163,0)
	for  quit:t'<+$get(seq)  do dropOldest(.t)
"RTN","VSLTAP",164,0)
	set ^XTMP("VSLTAP","tail")=t
"RTN","VSLTAP",165,0)
	quit
"RTN","VSLTAP",166,0)
	;
"RTN","VSLTAP",167,0)
	; ---------- auto-failover + state machine ----------
"RTN","VSLTAP",168,0)
	;
"RTN","VSLTAP",169,0)
disable(reason)	; Auto-failover: disable the tap, record an off-window (explicit, never silent).
"RTN","VSLTAP",170,0)
	; doc: @param reason  string  the interference signal (fault/copycost/latency/pressure)
"RTN","VSLTAP",171,0)
	new n
"RTN","VSLTAP",172,0)
	if $get(^VSLTAP("disabled"))'="" quit
"RTN","VSLTAP",173,0)
	set ^VSLTAP("disabled")=reason
"RTN","VSLTAP",174,0)
	set n=+$get(^VSLTAP("_offwindows"))+1
"RTN","VSLTAP",175,0)
	set ^VSLTAP("_offwindows")=n
"RTN","VSLTAP",176,0)
	set ^VSLTAP("_offwindows",n)=$horolog_"^"_reason_"^"
"RTN","VSLTAP",177,0)
	quit
"RTN","VSLTAP",178,0)
	;
"RTN","VSLTAP",179,0)
disabled()	; The auto-failover reason, or "" if armed/clean.
"RTN","VSLTAP",180,0)
	quit $get(^VSLTAP("disabled"))
"RTN","VSLTAP",181,0)
	;
"RTN","VSLTAP",182,0)
rearm()	; Re-arm after a clean cool-down (D-4): clear the disable + close the off-window.
"RTN","VSLTAP",183,0)
	new n
"RTN","VSLTAP",184,0)
	kill ^VSLTAP("disabled")
"RTN","VSLTAP",185,0)
	set n=+$get(^VSLTAP("_offwindows"))
"RTN","VSLTAP",186,0)
	if n,$piece($get(^VSLTAP("_offwindows",n)),"^",3)="" set $piece(^VSLTAP("_offwindows",n),"^",3)=$horolog
"RTN","VSLTAP",187,0)
	quit
"RTN","VSLTAP",188,0)
	;
"RTN","VSLTAP",189,0)
offWindows(out)	; Populate out(1..N) with the recorded off-windows; return the count.
"RTN","VSLTAP",190,0)
	; doc: @param out  array  by-ref; killed then filled with open^reason^close rows
"RTN","VSLTAP",191,0)
	new n,i
"RTN","VSLTAP",192,0)
	kill out
"RTN","VSLTAP",193,0)
	set n=+$get(^VSLTAP("_offwindows"))
"RTN","VSLTAP",194,0)
	for i=1:1:n set out(i)=$get(^VSLTAP("_offwindows",i))
"RTN","VSLTAP",195,0)
	quit n
"RTN","VSLTAP",196,0)
	;
"RTN","VSLTAP",197,0)
state()	; The standby state-machine label (spec §8.1).
"RTN","VSLTAP",198,0)
	; doc: @returns string OFF | AUTO-DISABLED | UNHEALTHY | ACTIVE | ARMED-IDLE
"RTN","VSLTAP",199,0)
	if $$cfg("mode","off")'="armed" quit "OFF"
"RTN","VSLTAP",200,0)
	if $$disabled()'="" quit "AUTO-DISABLED"
"RTN","VSLTAP",201,0)
	if '$$healthy() quit "UNHEALTHY"
"RTN","VSLTAP",202,0)
	if $$enabled() quit "ACTIVE"
"RTN","VSLTAP",203,0)
	quit "ARMED-IDLE"
"RTN","VSLTAP",204,0)
	;
"RTN","VSLTAP",205,0)
	; ---------- liveness ----------
"RTN","VSLTAP",206,0)
	;
"RTN","VSLTAP",207,0)
heartbeat()	; Stamp the liveness heartbeat (the watchdog beats this every N seconds).
"RTN","VSLTAP",208,0)
	set ^VSLTAP("hb")=$horolog
"RTN","VSLTAP",209,0)
	quit
