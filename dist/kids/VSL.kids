	; doc: @param res  array   by-ref: res("matched"/"mismatch"/"missing"/"extra")
"RTN","VSLTAPFC",100,0)
	; doc: @param ts   string  capture timestamp (default $H)
"RTN","VSLTAPFC",101,0)
	; doc: @returns    string  one RFC-8259 JSON object summarising the run
