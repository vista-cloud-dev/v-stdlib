"RTN","VSLIO",63,0)
	; doc: @returns numeric  bytes read (0 on timeout/EOF)
"RTN","VSLIO",64,0)
	new x,pio
"RTN","VSLIO",65,0)
	set buf="",pio=$io
"RTN","VSLIO",66,0)
	use id read x#maxlen:timeout
"RTN","VSLIO",67,0)
	use pio
"RTN","VSLIO",68,0)
	set buf=x
"RTN","VSLIO",69,0)
	quit $length(x)
"RTN","VSLIO",70,0)
	;
"RTN","VSLIO",71,0)
write(id,buf)	; Raw-write `buf` to a connected handle.
"RTN","VSLIO",72,0)
	; doc: @param   id       string   a handle from $$connect (the device)
