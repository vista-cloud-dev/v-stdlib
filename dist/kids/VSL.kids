"RTN","VSLIO",136,0)
	set m=m_nl_"    + the ISTLSSERVERCONF-XUSUDO validator (#7617), then flip $$tlsAvailable to 1."
"RTN","VSLIO",137,0)
	set m=m_nl_" 3. Tracked with STDNET's TLS gap (m-stdlib docs/tracking/discoveries.md, 2026-06-16)."
"RTN","VSLIO",138,0)
	quit m
"RTN","VSLIO",139,0)
	;
