"RTN","VSLTAP",288,0)
	new seq,cap,kind,gref,pl,wl,cc,hash,enc
"RTN","VSLTAP",289,0)
	; fault-injection seam (mirrors write1) — the §6.2 exit-gate (b) lever.
"RTN","VSLTAP",290,0)
	if +$$cfg("faultinject",0) set $ecode=",U-VSLTAP-INJECT,"
"RTN","VSLTAP",291,0)
