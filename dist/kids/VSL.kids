"RTN","VSLTAPFC",53,0)
	set hash=$$valueOf^STDJSON($get(t("hash")))
"RTN","VSLTAPFC",54,0)
	quit (hash=$$sha256^STDCRYPTO($$payloadOf(line)))
"RTN","VSLTAPFC",55,0)
