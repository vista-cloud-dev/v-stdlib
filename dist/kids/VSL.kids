"RTN","VSLFS",105,0)
	. do:seq=+seq addText(seq,.ERR,.m,nl)
"RTN","VSLFS",106,0)
	. set seq=$order(ERR("DIERR",seq))
"RTN","VSLFS",107,0)
	set ^TMP($job,"vslfs","err")=m
"RTN","VSLFS",108,0)
	quit
"RTN","VSLFS",109,0)
	;
"RTN","VSLFS",110,0)
addText(seq,ERR,m,nl)	; Append every TEXT line of DIERR `seq` to `m` (by ref).
"RTN","VSLFS",111,0)
	new ln
"RTN","VSLFS",112,0)
	set ln=$order(ERR("DIERR",seq,"TEXT",""))
"RTN","VSLFS",113,0)
