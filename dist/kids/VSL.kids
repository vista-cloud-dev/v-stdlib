"RTN","VSLTAPFC",44,0)
	set pl=$$valueOf^STDJSON($get(t("payload")))
"RTN","VSLTAPFC",45,0)
	if $$valueOf^STDJSON($get(t("enc")))="base64" quit $$decode^STDB64(pl)
"RTN","VSLTAPFC",46,0)
