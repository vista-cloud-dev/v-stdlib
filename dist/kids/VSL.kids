"RTN","VSLIO",90,0)
	;
"RTN","VSLIO",91,0)
lastError()	; The last VSLIO error message (e.g. the TLS-gap remediation).
"RTN","VSLIO",92,0)
	; doc: @returns string  ^TMP($job,"vslio","err"), or "" if none
"RTN","VSLIO",93,0)
