"RTN","VSLIO",97,0)
tlsAvailable()	; 0 — VSLIO has no wired TLS (engine TLS infra + XU*8.0*787 absent).
"RTN","VSLIO",98,0)
	; doc: @returns bool  always 0 today: raw plaintext only (a known, tracked gap)
"RTN","VSLIO",99,0)
	; doc: Check before any secure use; $$tlsHelp has remediation.
"RTN","VSLIO",100,0)
	quit 0
"RTN","VSLIO",101,0)
	;
"RTN","VSLIO",102,0)
