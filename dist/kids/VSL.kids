"RTN","VSLS3",137,0)
gStep(nref,pfx,out)	; (private) advance to the next "g" descendant; append its serialized node ("" nref stops the walk).
"RTN","VSLS3",138,0)
	set nref=$query(@nref)
"RTN","VSLS3",139,0)
