"RTN","VSLTAPFC",73,0)
	new seq
"RTN","VSLTAPFC",74,0)
	kill res
"RTN","VSLTAPFC",75,0)
	set res("matched")=0,res("mismatch")=0,res("missing")=0,res("extra")=0
"RTN","VSLTAPFC",76,0)
	set seq=""
"RTN","VSLTAPFC",77,0)
	for  do recOne(.seq,.corpus,.envs,.res) quit:seq=""
"RTN","VSLTAPFC",78,0)
	set seq=""
"RTN","VSLTAPFC",79,0)
	for  do extraOne(.seq,.corpus,.envs,.res) quit:seq=""
"RTN","VSLTAPFC",80,0)
