"RTN","VSLS3",106,0)
	;
"RTN","VSLS3",107,0)
today()	; (private) today's date as YYYYMMDD, from $H via STDDATE.
"RTN","VSLS3",108,0)
	new z,y,m,d
"RTN","VSLS3",109,0)
	set z=+$horolog-47117
"RTN","VSLS3",110,0)
	do civilFromDays^STDDATE(z,.y,.m,.d)
"RTN","VSLS3",111,0)
	quit (y*10000)+(m*100)+d_""
"RTN","VSLS3",112,0)
	;
"RTN","VSLS3",113,0)
	; ---------- the config seam (S3 ctx from ^VSLTAP) ----------
"RTN","VSLS3",114,0)
