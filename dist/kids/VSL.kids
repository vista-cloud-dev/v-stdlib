"RTN","VSLTAPFC",88,0)
	quit
"RTN","VSLTAPFC",89,0)
	;
"RTN","VSLTAPFC",90,0)
extraOne(seq,corpus,envs,res)	; (private) advance to the next shipped seq; count any with no corpus source.
"RTN","VSLTAPFC",91,0)
	set seq=$order(envs(seq))
"RTN","VSLTAPFC",92,0)
	if seq="" quit
"RTN","VSLTAPFC",93,0)
	if '$data(corpus(seq)) set res("extra")=res("extra")+1
"RTN","VSLTAPFC",94,0)
