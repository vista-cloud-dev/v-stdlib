"RTN","VSLTAP",81,0)
	; doc: @example   kill ^VSLTAP do arm^VSLTAP(),setConsumer^VSLTAP(1) do eq^STDASSERT(.pass,.fail,$$enabled^VSLTAP(),1,"consumer present -> egress enabled") kill ^VSLTAP
"RTN","VSLTAP",82,0)
