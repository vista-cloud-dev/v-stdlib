record(us,bytes,denied)	; Record one capture sample: a denial, or a write (+bytes, +optional latency).
"RTN","VSLTAPHL",33,0)
	; doc: @param us      numeric  capture latency in microseconds (0 -> no latency sample)
"RTN","VSLTAPHL",34,0)
	; doc: @param bytes   numeric  bytes copied into the buffer
"RTN","VSLTAPHL",35,0)
	; doc: @param denied  bool     1 iff the consumer-gate denied this capture (no write)
"RTN","VSLTAPHL",36,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do record^VSLTAPHL(120,50,0),record^VSLTAPHL(80,40,0),record^VSLTAPHL(0,0,1) do eq^STDASSERT(.pass,.fail,$$writes^VSLTAPHL(),2,"two capture writes counted (the denied sample is not a write)")
"RTN","VSLTAPHL",37,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do record^VSLTAPHL(120,50,0),record^VSLTAPHL(80,40,0) do eq^STDASSERT(.pass,.fail,$$bytes^VSLTAPHL(),90,"bytes-to-buffer summed across writes")
"RTN","VSLTAPHL",38,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do record^VSLTAPHL(0,0,1) do eq^STDASSERT(.pass,.fail,$$denied^VSLTAPHL(),1,"one consumer-gate denial counted")
"RTN","VSLTAPHL",39,0)
	new b
"RTN","VSLTAPHL",40,0)
	if +$get(denied) do incr("denied") quit
"RTN","VSLTAPHL",41,0)
	do incr("writes")
"RTN","VSLTAPHL",42,0)
	set b=+$get(bytes)
"RTN","VSLTAPHL",43,0)
	set ^VSLTAP("hl","bytes")=+$get(^VSLTAP("hl","bytes"))+b
"RTN","VSLTAPHL",44,0)
	if +$get(us)>0 do sample(+us)
"RTN","VSLTAPHL",45,0)
	quit
"RTN","VSLTAPHL",46,0)
	;
"RTN","VSLTAPHL",47,0)
incr(k)	; (private) increment counter ^VSLTAP("hl",k).
"RTN","VSLTAPHL",48,0)
	set ^VSLTAP("hl",k)=+$get(^VSLTAP("hl",k))+1
"RTN","VSLTAPHL",49,0)
	quit
"RTN","VSLTAPHL",50,0)
	;
"RTN","VSLTAPHL",51,0)
sample(us)	; (private) append a latency sample into a bounded window for percentiles.
"RTN","VSLTAPHL",52,0)
	new n,cap
"RTN","VSLTAPHL",53,0)
	set cap=200
"RTN","VSLTAPHL",54,0)
	set n=+$get(^VSLTAP("hl","scount"))+1
"RTN","VSLTAPHL",55,0)
	set ^VSLTAP("hl","scount")=n
"RTN","VSLTAPHL",56,0)
	set ^VSLTAP("hl","s",((n-1)#cap)+1)=us
"RTN","VSLTAPHL",57,0)
	quit
"RTN","VSLTAPHL",58,0)
	;
"RTN","VSLTAPHL",59,0)
writes()	; Captured-record count.
"RTN","VSLTAPHL",60,0)
	quit +$get(^VSLTAP("hl","writes"))
"RTN","VSLTAPHL",61,0)
	;
"RTN","VSLTAPHL",62,0)
bytes()	; Bytes-to-buffer count.
"RTN","VSLTAPHL",63,0)
	quit +$get(^VSLTAP("hl","bytes"))
"RTN","VSLTAPHL",64,0)
	;
"RTN","VSLTAPHL",65,0)
denied()	; Consumer-gate denial count.
"RTN","VSLTAPHL",66,0)
	quit +$get(^VSLTAP("hl","denied"))
"RTN","VSLTAPHL",67,0)
	;
"RTN","VSLTAPHL",68,0)
pctl(p)	; The p-th percentile (nearest-rank) of the latency-sample window; 0 if none.
"RTN","VSLTAPHL",69,0)
	; doc: @param p   numeric  percentile 0..100
"RTN","VSLTAPHL",70,0)
	; doc: @returns   numeric  the nearest-rank sample value
"RTN","VSLTAPHL",71,0)
	; doc: @example   new i kill ^VSLTAP,^XTMP("VSLTAP") for i=1:1:100 do record^VSLTAPHL(i,1,0)  do true^STDASSERT(.pass,.fail,($$pctl^VSLTAPHL(50)'<1)&($$pctl^VSLTAPHL(50)'>100),"p50 of 1..100 falls within [1,100]")
"RTN","VSLTAPHL",72,0)
	; doc: @example   new i kill ^VSLTAP,^XTMP("VSLTAP") for i=1:1:100 do record^VSLTAPHL(i,1,0)  do true^STDASSERT(.pass,.fail,$$pctl^VSLTAPHL(95)'<$$pctl^VSLTAPHL(50),"p95 >= p50 (percentiles are monotonic)")
"RTN","VSLTAPHL",73,0)
	new j,cnt,tmp,idx,acc,res,v,done,cap,sc
"RTN","VSLTAPHL",74,0)
	set cap=200
"RTN","VSLTAPHL",75,0)
	set sc=+$get(^VSLTAP("hl","scount"))
"RTN","VSLTAPHL",76,0)
	set cnt=$select(sc>cap:cap,1:sc)
"RTN","VSLTAPHL",77,0)
	if 'cnt quit 0
"RTN","VSLTAPHL",78,0)
	for j=1:1:cnt do tally(.tmp,+$get(^VSLTAP("hl","s",j)))
"RTN","VSLTAPHL",79,0)
	set idx=$$ceil((p*cnt)/100)
"RTN","VSLTAPHL",80,0)
	if idx<1 set idx=1
"RTN","VSLTAPHL",81,0)
	set acc=0,res=0,v="",done=0
"RTN","VSLTAPHL",82,0)
	for  quit:done  do walk(.tmp,.v,.acc,.res,.done,idx)
"RTN","VSLTAPHL",83,0)
	quit res
"RTN","VSLTAPHL",84,0)
	;
"RTN","VSLTAPHL",85,0)
tally(tmp,v)	; (private) bucket one sample value into the value-keyed multiset.
"RTN","VSLTAPHL",86,0)
	set tmp(v)=+$get(tmp(v))+1
"RTN","VSLTAPHL",87,0)
	quit
"RTN","VSLTAPHL",88,0)
	;
"RTN","VSLTAPHL",89,0)
walk(tmp,v,acc,res,done,idx)	; (private) advance in value order, accumulating counts to the nearest rank.
"RTN","VSLTAPHL",90,0)
	set v=$order(tmp(v))
"RTN","VSLTAPHL",91,0)
	if v="" set done=1 quit
"RTN","VSLTAPHL",92,0)
	set acc=acc+tmp(v),res=v
"RTN","VSLTAPHL",93,0)
	if acc'<idx set done=1
"RTN","VSLTAPHL",94,0)
	quit
"RTN","VSLTAPHL",95,0)
	;
"RTN","VSLTAPHL",96,0)
ceil(x)	; (private) integer ceiling of a non-negative number.
"RTN","VSLTAPHL",97,0)
	quit (x\1)+((x>(x\1)))
"RTN","VSLTAPHL",98,0)
	;
"RTN","VSLTAPHL",99,0)
	; ---------- the A/B latency watchdog (feeds auto-failover) ----------
"RTN","VSLTAPHL",100,0)
	;
"RTN","VSLTAPHL",101,0)
abcheck(base,tapped)	; 1 iff (tapped - base) exceeds the pre-registered D-7 latency bound.
"RTN","VSLTAPHL",102,0)
	; doc: @param base    numeric  baseline (tap OFF) latency
"RTN","VSLTAPHL",103,0)
	; doc: @param tapped  numeric  tapped (tap ON) latency
"RTN","VSLTAPHL",104,0)
	; doc: @returns bool   the exact signal the §6.2 watchdog trips on
"RTN","VSLTAPHL",105,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") set ^VSLTAP("cfg","latbound")=100 do eq^STDASSERT(.pass,.fail,$$abcheck^VSLTAPHL(10,60),0,"tapped-base=50 <= 100 bound -> clean")
"RTN","VSLTAPHL",106,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") set ^VSLTAP("cfg","latbound")=100 do eq^STDASSERT(.pass,.fail,$$abcheck^VSLTAPHL(10,510),1,"tapped-base=500 > 100 bound -> trip")
"RTN","VSLTAPHL",107,0)
	quit ((+tapped-+base)>+$$cfg^VSLTAP("latbound",250))
"RTN","VSLTAPHL",108,0)
	;
"RTN","VSLTAPHL",109,0)
watchLatency(base,tapped)	; Trip auto-failover OFF when the tapped-vs-baseline delta breaches the bound.
"RTN","VSLTAPHL",110,0)
	; doc: @param base    numeric  baseline (tap OFF) latency
"RTN","VSLTAPHL",111,0)
	; doc: @param tapped  numeric  tapped (tap ON) latency
"RTN","VSLTAPHL",112,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do arm^VSLTAP(),setConsumer^VSLTAP(1) set ^VSLTAP("cfg","latbound")=100 do watchLatency^VSLTAPHL(10,10) do eq^STDASSERT(.pass,.fail,$$disabled^VSLTAP(),"","a within-bound sample does not disable the tap")
"RTN","VSLTAPHL",113,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do arm^VSLTAP(),setConsumer^VSLTAP(1) set ^VSLTAP("cfg","latbound")=100 do watchLatency^VSLTAPHL(10,500) do eq^STDASSERT(.pass,.fail,$$disabled^VSLTAP(),"latency","an over-bound sample self-disables with reason latency")
"RTN","VSLTAPHL",114,0)
	if $$abcheck(.base,.tapped) do disable^VSLTAP("latency")
"RTN","VSLTAPHL",115,0)
	quit
"RTN","VSLTAPHL",116,0)
	;
"RTN","VSLTAPHL",117,0)
beat()	; Update the liveness heartbeat (the watchdog's k8s-style liveness beat).
"RTN","VSLTAPHL",118,0)
	do heartbeat^VSLTAP()
"RTN","VSLTAPHL",119,0)
	quit
"RTN","VSLTAPHL",120,0)
	;
"RTN","VSLTAPHL",121,0)
	; ---------- standby readiness (idle != dead, §8.1) ----------
"RTN","VSLTAPHL",122,0)
	;
"RTN","VSLTAPHL",123,0)
ready()	; Standby readiness probe: 1 iff a gated/idle tap COULD capture if a consumer appeared.
"RTN","VSLTAPHL",124,0)
	; doc: @returns bool  checks (1) armed (2) not auto-disabled (3) heartbeat fresh
"RTN","VSLTAPHL",125,0)
	; doc: (4) the ^XTMP capture substrate is writable. Egress HEAD ping is Phase 3.
"RTN","VSLTAPHL",126,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do arm^VSLTAP(),beat^VSLTAPHL() do true^STDASSERT(.pass,.fail,$$ready^VSLTAPHL()=1,"readiness probe green while idle (substrate writable, fence armed, heartbeat fresh)")
"RTN","VSLTAPHL",127,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do arm^VSLTAP(),beat^VSLTAPHL() set ^VSLTAP("hb")=0 do true^STDASSERT(.pass,.fail,$$ready^VSLTAPHL()=0,"a stale heartbeat flips readiness red even with zero traffic")
"RTN","VSLTAPHL",128,0)
	if $$cfg^VSLTAP("mode","off")'="armed" quit 0
"RTN","VSLTAPHL",129,0)
	if $$disabled^VSLTAP()'="" quit 0
"RTN","VSLTAPHL",130,0)
	if '$$healthy^VSLTAP() quit 0
"RTN","VSLTAPHL",131,0)
	if '$$substrateWritable() quit 0
"RTN","VSLTAPHL",132,0)
	quit 1
"RTN","VSLTAPHL",133,0)
	;
"RTN","VSLTAPHL",134,0)
substrateWritable()	; (private) prove the ^XTMP capture substrate is writable, fenced, leaving no trace.
"RTN","VSLTAPHL",135,0)
	new ok,$etrap
"RTN","VSLTAPHL",136,0)
	set ok=1
"RTN","VSLTAPHL",137,0)
	set $etrap="set ok=0,$ecode="""" quit"
"RTN","VSLTAPHL",138,0)
	set ^XTMP("VSLTAP","probe")=$job
"RTN","VSLTAPHL",139,0)
	if +$get(^XTMP("VSLTAP","probe"))'=$job set ok=0
"RTN","VSLTAPHL",140,0)
	kill ^XTMP("VSLTAP","probe")
"RTN","VSLTAPHL",141,0)
	quit ok
"RTN","VSLTAPHL",142,0)
	;
"RTN","VSLTAPHL",143,0)
canary()	; Synthetic byte-exact round-trip of a tagged record through ^XTMP — touches no real RPC.
"RTN","VSLTAPHL",144,0)
	; doc: @returns bool  1 iff the capture substrate round-trips byte-exact on standby
"RTN","VSLTAPHL",145,0)
	; doc: Proves capture works while idle without perturbing the ring (the §8.1
"RTN","VSLTAPHL",146,0)
	; doc: synthetic monitor; the §15 harness run with a one-record corpus).
"RTN","VSLTAPHL",147,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do arm^VSLTAP(),beat^VSLTAPHL() do true^STDASSERT(.pass,.fail,$$canary^VSLTAPHL()=1,"canary proves capture-substrate works on standby (byte-exact round-trip)")
"RTN","VSLTAPHL",148,0)
	; doc: @example   kill ^VSLTAP,^XTMP("VSLTAP") do arm^VSLTAP(),beat^VSLTAPHL() set %=$$canary^VSLTAPHL() do eq^STDASSERT(.pass,.fail,$$size^VSLTAP(),0,"the canary leaves the real ring empty (no clinical-traffic perturbation)")
"RTN","VSLTAPHL",149,0)
	new tag,rb,ok,$etrap
"RTN","VSLTAPHL",150,0)
	set ok=1
"RTN","VSLTAPHL",151,0)
	set $etrap="set ok=0,$ecode="""" quit"
"RTN","VSLTAPHL",152,0)
	set tag="VSLTAP-CANARY^"_$job_"^heartbeat"
"RTN","VSLTAPHL",153,0)
	set ^XTMP("VSLTAP","canary")=tag
"RTN","VSLTAPHL",154,0)
	set rb=$get(^XTMP("VSLTAP","canary"))
"RTN","VSLTAPHL",155,0)
	kill ^XTMP("VSLTAP","canary")
"RTN","VSLTAPHL",156,0)
	if 'ok quit 0
"RTN","VSLTAPHL",157,0)
	quit (rb=tag)
"RTN","VSLTASK")
0^101^0^0
"RTN","VSLTASK",1,0)
VSLTASK	; v-stdlib — VistA TaskMan persistent-listener adapter (the process seam).
"RTN","VSLTASK",2,0)
	; doc: @exrun live
"RTN","VSLTASK",3,0)
	; doc: @exsafe transactional
"RTN","VSLTASK",4,0)
	;
"RTN","VSLTASK",5,0)
	; Binds the persistent-listener seam to Kernel TaskMan. A long-running VSL/
"RTN","VSLTASK",6,0)
	; VWEB socket listener is a TaskMan **persistent task**: $$PSET^%ZTLOAD marks
"RTN","VSLTASK",7,0)
	; a queued task persistent, so TaskMan automatically RE-RUNS it when the lock
"RTN","VSLTASK",8,0)
	; on ^%ZTSCH("TASK",n) is dropped — a self-healing listener (architecture
"RTN","VSLTASK",9,0)
	; §3.5). VSLTASK is a thin binding over the Supported ^%ZTLOAD programmer API
"RTN","VSLTASK",10,0)
	; (ICR #10063), NOT new machinery; portable diagnostics belong in STDLOG (v->m),
"RTN","VSLTASK",11,0)
	; never re-implemented here.
"RTN","VSLTASK",12,0)
	;
"RTN","VSLTASK",13,0)
	; Public API:
"RTN","VSLTASK",14,0)
	;   $$running^VSLTASK()            — 1 iff the TaskMan scheduler is live (=$$TM^%ZTLOAD)
"RTN","VSLTASK",15,0)
	;   $$stop^VSLTASK()              — 1 iff a stop has been requested (=$$S^%ZTLOAD)
"RTN","VSLTASK",16,0)
	;   $$persist^VSLTASK(ztsk)       — mark queued task `ztsk` self-restarting (=$$PSET^%ZTLOAD)
"RTN","VSLTASK",17,0)
	;   $$schedule^VSLTASK(entry,desc,when) — headless-queue a persistent listener -> its task#
"RTN","VSLTASK",18,0)
	;   $$lastError^VSLTASK()         — last error detail, else ""
"RTN","VSLTASK",19,0)
	;
"RTN","VSLTASK",20,0)
	; *** ERROR CONTRACT — loud on a malformed call / a real TaskMan fault ***
"RTN","VSLTASK",21,0)
	; A malformed call (no entry / no task#) or a TaskMan queue fault maps to a
"RTN","VSLTASK",22,0)
	; clean ,U-VSL-TASK-ARG, / ,U-VSL-TASK-QUEUE, $ECODE, with the detail in
"RTN","VSLTASK",23,0)
	; ^TMP($job,"vsltask","err") for $$lastError. A normal negative — "the
"RTN","VSLTASK",24,0)
	; scheduler is not running here" ($$running=0) or "no stop requested"
"RTN","VSLTASK",25,0)
	; ($$stop=0) — is NOT an error (kickoff decision 4). The flag-based $ETRAP
"RTN","VSLTASK",26,0)
	; pattern is used (NEVER zgoto — a zgoto trap aborts the resident harness 0/0,
"RTN","VSLTASK",27,0)
	; the M4 VSLLOG gotcha); OUR trap is cleared before any re-raise.
"RTN","VSLTASK",28,0)
	;
"RTN","VSLTASK",29,0)
	; Self-restart note: the restart CONTRACT is bound here ($$PSET^%ZTLOAD marks
"RTN","VSLTASK",30,0)
	; ^%ZTSCH("TASK",n,"P"); TaskMan re-runs on a lock drop). Observing a live
"RTN","VSLTASK",31,0)
	; restart needs the task body installed as a RESIDENT routine (the v-pkg
"RTN","VSLTASK",32,0)
	; install path) + lock manipulation, and a persistent task is deliberately
"RTN","VSLTASK",33,0)
	; un-KILLable — out of scope for a safe unit test (see VSLTASKTST).
"RTN","VSLTASK",34,0)
	;
"RTN","VSLTASK",35,0)
	quit
"RTN","VSLTASK",36,0)
	;
"RTN","VSLTASK",37,0)
	; ---------- the TaskMan binding (ICR #10063, Supported) ----------
"RTN","VSLTASK",38,0)
	;
"RTN","VSLTASK",39,0)
running()	; 1 iff the TaskMan scheduler is live (its ^%ZTSCH("RUN") heartbeat is fresh).
"RTN","VSLTASK",40,0)
	; doc: @returns          bool     1 iff TaskMan is running (the self-heal precondition); 0 otherwise
"RTN","VSLTASK",41,0)
	; doc: @example         do true^STDASSERT(.pass,.fail,($$running^VSLTASK()=0)!($$running^VSLTASK()=1),"$$running returns a clean boolean (resolves $$TM^%ZTLOAD)")
"RTN","VSLTASK",42,0)
	; doc: @icr 10063 @call $$TM^%ZTLOAD @status Supported @custodian XU @source XU/krn_8_0_dg_taskman_ug#tmztload-check-if-taskman-is-running
"RTN","VSLTASK",43,0)
	quit ''$$TM^%ZTLOAD()
"RTN","VSLTASK",44,0)
	;
"RTN","VSLTASK",45,0)
stop()	; 1 iff a stop has been requested of the currently-running task (cooperative stop).
"RTN","VSLTASK",46,0)
	; doc: @returns          bool     1 iff the listener loop should stop; 0 when not in a task / no stop pending
"RTN","VSLTASK",47,0)
	; doc: @example         do true^STDASSERT(.pass,.fail,$$stop^VSLTASK()=0,"$$stop=0 when not running as a TaskMan task (the cooperative-stop check)")
"RTN","VSLTASK",48,0)
	; doc: @icr 10063 @call $$S^%ZTLOAD @status Supported @custodian XU @source XU/krn_8_0_dg_taskman_ug#sztload-check-for-task-stop-request
"RTN","VSLTASK",49,0)
	quit ''$$S^%ZTLOAD
"RTN","VSLTASK",50,0)
	;
"RTN","VSLTASK",51,0)
persist(ztsk)	; Mark queued task `ztsk` persistent so TaskMan self-restarts it on a lock drop.
"RTN","VSLTASK",52,0)
	; doc: @param   ztsk     numeric  the task number (from $$schedule / ^%ZTLOAD)
"RTN","VSLTASK",53,0)
	; doc: @returns          bool     1 iff the task was marked persistent, else 0 (task not queued)
"RTN","VSLTASK",54,0)
	; doc: @raises  U-VSL-TASK-ARG   the call is malformed (no positive task number)
"RTN","VSLTASK",55,0)
	; doc: @illustrative   the success path marks a queued task persistent (un-KILLable) on a shared live TaskMan; only the malformed-call contract is safely shown
"RTN","VSLTASK",56,0)
	; doc: @example         do raises^STDASSERT(.pass,.fail,"set x=$$persist^VSLTASK("""")","U-VSL-TASK-ARG","$$persist with no task# raises U-VSL-TASK-ARG")
"RTN","VSLTASK",57,0)
	; doc: @icr 10063 @call $$PSET^%ZTLOAD @status Supported @custodian XU @source XU/krn_8_0_dg_taskman_ug#psetztload-set-task-as-persistent
"RTN","VSLTASK",58,0)
	if +$get(ztsk)'>0 do raise("U-VSL-TASK-ARG","persist: a positive task number is required") quit ""
"RTN","VSLTASK",59,0)
	quit ''$$PSET^%ZTLOAD(ztsk)
"RTN","VSLTASK",60,0)
	;
"RTN","VSLTASK",61,0)
schedule(entry,desc,when)	; Headless-queue a persistent listener at `entry`; return its task number.
"RTN","VSLTASK",62,0)
	; doc: @param   entry    string   the task entry reference (TAG^ROUTINE)
"RTN","VSLTASK",63,0)
	; doc: @param   desc     string   a human description (optional)
"RTN","VSLTASK",64,0)
	; doc: @param   when     string   $H start time (optional; default now). MUST be <=5-digit $H or "@"
"RTN","VSLTASK",65,0)
	; doc: @returns          numeric  the queued task number
"RTN","VSLTASK",66,0)
	; doc: @raises  U-VSL-TASK-ARG    no entry reference supplied
"RTN","VSLTASK",67,0)
	; doc: @raises  U-VSL-TASK-QUEUE  the TaskMan queue / persist failed
"RTN","VSLTASK",68,0)
	; doc: @raisesnodemo U-VSL-TASK-QUEUE  reachable only via a genuinely-failed live TaskMan queue (side-effecting, non-deterministic); not safely triggerable in an example
"RTN","VSLTASK",69,0)
	; doc: @illustrative   the success path queues a real, persistent (un-KILLable) TaskMan task on a shared live VistA — a side effect that cannot be cleanly undone; only the malformed-call contract is safely shown
"RTN","VSLTASK",70,0)
	; doc: @example         do raises^STDASSERT(.pass,.fail,"set x=$$schedule^VSLTASK("""",""ZZ"")","U-VSL-TASK-ARG","$$schedule with no entry raises U-VSL-TASK-ARG")
"RTN","VSLTASK",71,0)
	new $etrap,ztsk,ok
"RTN","VSLTASK",72,0)
	if $get(entry)="" do raise("U-VSL-TASK-ARG","schedule: an entry reference is required") quit ""
"RTN","VSLTASK",73,0)
	set ok=1
"RTN","VSLTASK",74,0)
	set $etrap="set ok=0,$ecode="""" quit"
"RTN","VSLTASK",75,0)
	set ztsk=$$queue(entry,$get(desc),$get(when))
"RTN","VSLTASK",76,0)
	set $etrap=""
"RTN","VSLTASK",77,0)
	if 'ok!(+ztsk'>0) do raise("U-VSL-TASK-QUEUE","schedule: TaskMan queue failed") quit ""
"RTN","VSLTASK",78,0)
	if '$$PSET^%ZTLOAD(ztsk) do raise("U-VSL-TASK-QUEUE","schedule: could not mark task "_ztsk_" persistent") quit ""
"RTN","VSLTASK",79,0)
	quit ztsk
"RTN","VSLTASK",80,0)
	;
"RTN","VSLTASK",81,0)
lastError()	; The last VSLTASK error message (the composed malformed-call / fault detail).
"RTN","VSLTASK",82,0)
	; doc: @returns          string   ^TMP($job,"vsltask","err"), or "" if none
"RTN","VSLTASK",83,0)
	; doc: @example         do raises^STDASSERT(.pass,.fail,"set x=$$persist^VSLTASK("""")","U-VSL-TASK-ARG","arm an error") do contains^STDASSERT(.pass,.fail,$$lastError^VSLTASK(),"task number","$$lastError carries the malformed-call detail after a raise")
"RTN","VSLTASK",84,0)
	quit $get(^TMP($job,"vsltask","err"))
"RTN","VSLTASK",85,0)
	;
"RTN","VSLTASK",86,0)
	; ---------- internals ----------
"RTN","VSLTASK",87,0)
	;
"RTN","VSLTASK",88,0)
queue(entry,desc,when)	; (private) headless ^%ZTLOAD queue (no device); return the task number, else 0.
"RTN","VSLTASK",89,0)
	; doc: @illustrative   private; runs ^%ZTLOAD which queues a real TaskMan task on a shared live VistA — a side effect that cannot be cleanly undone in a unit test
"RTN","VSLTASK",90,0)
	; doc: @icr 10063 @call ^%ZTLOAD @status Supported @custodian XU @source XU/krn_8_0_tm#callable-entry-points
"RTN","VSLTASK",91,0)
	new ZTRTN,ZTDESC,ZTIO,ZTDTH,ZTSK
"RTN","VSLTASK",92,0)
	set ZTRTN=entry,ZTIO=""
"RTN","VSLTASK",93,0)
	set ZTDESC=$select(desc'="":desc,1:"VSL persistent listener")
"RTN","VSLTASK",94,0)
	set ZTDTH=$select(when'="":when,1:$horolog)
"RTN","VSLTASK",95,0)
	do ^%ZTLOAD
"RTN","VSLTASK",96,0)
	quit +$get(ZTSK)
"RTN","VSLTASK",97,0)
	;
"RTN","VSLTASK",98,0)
raise(code,msg)	; (private) stash the detail, then raise the clean ,<code>, $ECODE.
"RTN","VSLTASK",99,0)
	set ^TMP($job,"vsltask","err")=msg
"RTN","VSLTASK",100,0)
	set $ecode=","_code_","
"RTN","VSLTASK",101,0)
	quit
