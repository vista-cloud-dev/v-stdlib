reconcile(corpus,envs,res)	; Reconcile a generated corpus against the read-back envelopes, by sequence.
"RTN","VSLTAPFC",65,0)
	; doc: @param corpus  array  by-ref: corpus(seq) = the generated verbatim record
"RTN","VSLTAPFC",66,0)
